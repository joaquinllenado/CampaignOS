{
  "name": "nozo-hack",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run build:api && bun run build:web",
    "build:api": "bun run --cwd apps/api build",
    "build:web": "bun run --cwd apps/web build",
    "typecheck": "bun run --cwd apps/api typecheck && bun run --cwd apps/web typecheck",
    "test:nia:ingest": "bun run scripts/nia-ingest-test-documents.ts",
    "test:nia:ingest:poll": "bun run scripts/nia-ingest-test-documents.ts --poll",
    "test:nia:query": "bun run scripts/nia-query-test-sources.ts",
    "test:nia:e2e": "bun run scripts/nia-e2e-test-documents.ts",
    "test:agent:nia": "bun run scripts/agent-nia-context-test.ts",
    "test:agent:nia:e2e": "bun run scripts/agent-nia-context-test.ts --ingest-test-documents"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "concurrently": "^9.2.1",
    "nia-ai-ts": "^0.5.0",
    "typescript": "^6.0.3"
  }
}
