# Place this file at the repository root. The API loads it via --env-file ../../.env (see apps/api/package.json).

API_PORT=3041
WEB_PORT=5173
VITE_API_URL=http://localhost:3041

# Brand context indexing (PDF, spreadsheets, plain text uploads → Nia)
NIA_API_KEY=
NIA_BASE_URL=https://apigcp.trynia.ai/v2
# Optional: per-file ingest wall time in ms (default 180000). Increase for very large PDFs if indexing is legitimately slow.
#NIA_INGEST_TIMEOUT_MS=300000

# Campaign intelligence agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
REACHER_API_KEY=
REACHER_BASE_URL=https://api.reacherapp.com/public/v1
# Optional: default shop / collab ids for local runs (see web demo `DEMO_REACHER_SAMPLE_TARGET_COLLAB_5_1_26`)
#REACHER_DEFAULT_SHOP_ID=1183
#REACHER_DEFAULT_CAMPAIGN_ID=66330
